# ============================================
# MediChain AI — Unified Environment Config
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ============================================
# AI Services
# ============================================

# NVIDIA NIM (Llama 4 Maverick)
# Get from: https://build.nvidia.com
NVIDIA_API_KEY=nvapi-your_nvidia_api_key_here

# HuggingFace (Bio_ClinicalBERT)
# Get from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_your_huggingface_token_here

# Legacy (can remove after full migration)
GOOGLE_API_KEY=your_google_api_key_here

# ============================================
# Authentication
# ============================================

# Clerk (replaces MetaMask for user auth)
# Get from: https://dashboard.clerk.com

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Clerk URLs (optional - defaults work for most cases)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/patient
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/patient

# ============================================
# Database (InsForge)
# ============================================

# InsForge Backend
# Get from: https://insforge.dev
INSFORGE_BASE_URL=https://your-project.insforge.app
INSFORGE_SERVICE_KEY=your_insforge_service_key_here

# Optional: Anonymous key for client-side operations
NEXT_PUBLIC_INSFORGE_BASE_URL=https://your-project.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=your_insforge_anon_key_here

# ============================================
# WhatsApp Integration (Twilio)
# ============================================

# Twilio Credentials
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Webhook verification token (for Meta WhatsApp Business API)
WHATSAPP_VERIFY_TOKEN=medichain_secure_token_2026

# Your public URL (set when deploying)
PUBLIC_WEBHOOK_URL=https://your-domain.com

# ============================================
# AI Doctor Avatar (Tavus)
# ============================================

# Tavus API
# Get from: https://tavus.io
TAVUS_API_KEY=your_tavus_api_key_here
TAVUS_REPLICA_ID=your_tavus_replica_id_here

# ============================================
# IPFS Storage (Pinata)
# ============================================

# Pinata Credentials
# Get from: https://pinata.cloud
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_KEY=your_pinata_secret_key_here
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs

# ============================================
# Security
# ============================================

# Database Encryption Vault Master Key
# Generate via: python -c "import secrets; print(secrets.token_hex(32))"
VAULT_MASTER_KEY=your_64_character_hex_key_here

# Server Encryption Secret (for WhatsApp message encryption)
# Generate via: python -c "import secrets; print(secrets.token_hex(32))"
SERVER_ENCRYPTION_SECRET=your_64_character_hex_key_here

# ============================================
# Backend Configuration
# ============================================

# Backend API URL (for frontend to connect)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Allowed CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# Blockchain (Optional)
# ============================================

# Ethereum RPC URL (local Hardhat node or remote provider)
ETHEREUM_RPC_URL=http://127.0.0.1:8545

# Ethereum Private Key (for backend to sign transactions)
ETHEREUM_PRIVATE_KEY=your_ethereum_private_key_here

# Smart Contract Addresses (public by nature)
CONTRACT_ADDRESS=your_deployed_contract_address_here
NEXT_PUBLIC_CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
NEXT_PUBLIC_RESEARCH_TOKEN_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
NEXT_PUBLIC_STUDY_REGISTRY_ADDRESS=0x9fE46736679d2D9a65F0992F2272dE9f3c7fa6e0

# ============================================
# Development
# ============================================

# Environment
NODE_ENV=development

# Logging
LOG_LEVEL=info
