# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# AI Services
NVIDIA_API_KEY=your_nvidia_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# MedGemma Gradio API - Multiple Hugging Face Tokens (comma-separated)
# Add multiple tokens for automatic fallback when one runs out of credits
# Example: HUGGINGFACE_TOKENS=hf_token1,hf_token2,hf_token3
# Leave empty for public access (no authentication, subject to rate limits)
HUGGINGFACE_TOKENS=

# Google Cloud Platform (for MedGemma on Vertex AI)
GCP_PROJECT_ID=medichain
GCP_LOCATION=asia-southeast1
MEDGEMMA_ENDPOINT_ID=mg-endpoint-0bdaa5e2-3c4b-4c34-89eb-3cbff9035895
# GCP_CREDENTIALS_JSON should be the full JSON service account key as a single-line string
# Get this from: GCP Console → IAM & Admin → Service Accounts → Create Service Account → Add Key (JSON)
# Grant role: Vertex AI User
# Example: {"type":"service_account","project_id":"medichain","private_key_id":"...","private_key":"...","client_email":"..."}
GCP_CREDENTIALS_JSON={"type":"service_account","project_id":"medichain","private_key":"REPLACE_WITH_YOUR_SERVICE_ACCOUNT_KEY"}

# Legacy (can remove after migration)
GOOGLE_API_KEY=your_google_api_key_here

# Database
INSFORGE_BASE_URL=https://your-project.insforge.app
INSFORGE_SERVICE_KEY=your_insforge_service_or_anon_key_here

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Tavus AI Doctor
TAVUS_API_KEY=your_tavus_api_key_here
TAVUS_REPLICA_ID=your_tavus_replica_id_here

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# Pinata IPFS
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_KEY=your_pinata_secret_key_here
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs

# Database Encryption Vault Master Key
# Generate via Python: import secrets; secrets.token_hex(32)
VAULT_MASTER_KEY=your_32_byte_hex_key_here

# Server Encryption Secret (for WhatsApp message encryption)
# Generate via Python: import secrets; secrets.token_hex(32)
SERVER_ENCRYPTION_SECRET=your_32_byte_hex_key_here

# Ethereum Blockchain
ETHEREUM_RPC_URL=http://127.0.0.1:8545
ETHEREUM_PRIVATE_KEY=your_ethereum_private_key_here
CONTRACT_ADDRESS=your_deployed_contract_address_here

# Privy MPC Wallet Authentication (backend verification)
PRIVY_APP_ID=your_privy_app_id_here
PRIVY_APP_SECRET=your_privy_app_secret_here
